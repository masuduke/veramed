# ── DATABASE ──────────────────────────────────
DATABASE_URL="postgresql://veramed:password@localhost:5432/veramed_db"
REDIS_URL="redis://localhost:6379"

# ── AUTH ──────────────────────────────────────
JWT_ACCESS_SECRET="change-me-to-a-random-64-char-hex-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-hex-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
BCRYPT_ROUNDS=12
ENCRYPTION_KEY="change-me-to-32-byte-hex-for-aes256"

# ── AWS S3 ────────────────────────────────────
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_S3_BUCKET="veramed-medical-reports"
S3_URL_EXPIRY_SECONDS=900

# ── AI ────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="claude-sonnet-4-20250514"
AI_MAX_TOKENS=2000
# OPENAI_API_KEY="sk-..." # alternative

# ── STRIPE ────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── EMAIL ─────────────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="noreply@veramed.health"

# ── APP ───────────────────────────────────────
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
